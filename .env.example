# =========================================================================
# STBet Tracker Environment Configurations
# Copy this file to '.env' and fill in your details for local execution.
# For GitHub deployment, add these keys under Settings > Secrets and Variables > Actions.
# =========================================================================

# Option 1: Standard HTTP/HTTPS Proxy (e.g. rotating residential proxy URL)
# Format: http://username:password@proxy_host:proxy_port
PROXY_URL=

# Option 2: ScraperAPI Key (Bypasses Cloudflare / IP blocks automatically)
# Register at: https://www.scraperapi.com
SCRAPER_API_KEY=

# Option 3: ZenRows API Key (Premium rotating proxies with WAF bypass)
# Register at: https://www.zenrows.com
ZENROWS_API_KEY=
